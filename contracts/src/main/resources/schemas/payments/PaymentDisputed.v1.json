{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentDisputed",
  "type": "object",
  "required": ["orderId", "paymentId", "disputeAmountCents", "currency"],
  "properties": {
    "orderId": { "type": "string", "format": "uuid" },
    "paymentId": { "type": "string", "format": "uuid" },
    "disputeAmountCents": { "type": "integer", "minimum": 0 },
    "currency": { "type": "string" },
    "reason": { "type": "string" }
  }
}
