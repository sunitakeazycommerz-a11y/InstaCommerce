{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderPacked",
  "type": "object",
  "required": ["orderId", "userId", "packedAt"],
  "properties": {
    "orderId": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "storeId": { "type": "string" },
    "packedAt": { "type": "string", "format": "date-time" },
    "pickupLat": { "type": "number", "description": "Latitude of the pickup store location" },
    "pickupLng": { "type": "number", "description": "Longitude of the pickup store location" }
  }
}
