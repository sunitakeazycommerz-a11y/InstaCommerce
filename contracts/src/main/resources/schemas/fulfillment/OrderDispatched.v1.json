{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderDispatched",
  "type": "object",
  "required": ["orderId", "userId", "riderId", "riderName", "estimatedMinutes", "dispatchedAt"],
  "properties": {
    "orderId": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "riderId": { "type": "string", "format": "uuid" },
    "riderName": { "type": "string" },
    "estimatedMinutes": { "type": "integer", "minimum": 0 },
    "dispatchedAt": { "type": "string", "format": "date-time" }
  }
}
